# Default: let Git auto-detect text files and normalize to LF in the repo.
* text=auto eol=lf

# Shell scripts and SQL must always be LF — running on Linux containers/servers,
# CRLF breaks shebang resolution (`/bin/bash^M: bad interpreter`) and psql input.
*.sh   text eol=lf
*.bash text eol=lf
*.sql  text eol=lf

# Source code: enforce LF for cross-platform consistency (Win/Mac/Linux contributors).
*.java       text eol=lf
*.kt         text eol=lf
*.kts        text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.xml        text eol=lf
*.properties text eol=lf
*.gradle     text eol=lf
*.md         text eol=lf
Dockerfile   text eol=lf
*.dockerfile text eol=lf

# Windows-only files keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files: never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.jar  binary
*.war  binary
*.zip  binary
*.gz   binary
