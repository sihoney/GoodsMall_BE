# AWS deployment environment template

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Database
DB_URL=jdbc:postgresql://<db-ec2-private-ip-or-dns>:5432/goods_mall
DB_USER_NAME=goods
DB_USER_PASSWORD=change-me
DB_SEED_ENABLED=false

# Kafka / Redis
SPRING_KAFKA_BOOTSTRAP_SERVERS=<kafka-bootstrap-servers>
REDIS_HOST=<redis-host>
REDIS_PORT=6379

# AWS S3
AWS_ACCESS_KEY=<aws-access-key>
AWS_SECRET_KEY=<aws-secret-key>

# Security
JWT_SECRET_KEY=replace-with-strong-secret

# Front URL
FRONTEND_BASE_URL=https://www.goods-mall.shop

# Toss Payments
TOSS_PAYMENTS_CLIENT_KEY=<toss-client-key>
TOSS_PAYMENTS_SECRET_KEY=<toss-secret-key>

# AI Recommendation
OPENAI_API_KEY=<openai-api-key>
