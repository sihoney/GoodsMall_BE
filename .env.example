POSTGRES_DB=goods_mall
POSTGRES_USER=goods
POSTGRES_PASSWORD=change-me

DB_URL=jdbc:postgresql://postgres:5432/goods_mall
DB_USER_NAME=goods
DB_USER_PASSWORD=change-me
DB_SEED_ENABLED=false
DB_SEED_LOCATIONS=

SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
REDIS_HOST=redis
REDIS_PORT=6379
PAYMENT_KAFKA_TOPIC_MEMBER_CREATED=member-signed-up
PAYMENT_KAFKA_TOPIC_ORDER_PAYMENT_REQUESTED=order.payment-requested
PAYMENT_KAFKA_TOPIC_ORDER_PAYMENT_RESULT=payment.order-payment-result
PAYMENT_KAFKA_TOPIC_ORDER_DELIVERY_COMPLETED=order.delivery-completed
PAYMENT_KAFKA_TOPIC_ORDER_PURCHASE_CONFIRMED=order.purchase-confirmed
PAYMENT_KAFKA_TOPIC_SETTLEMENT_CANDIDATE_CREATED=payment.settlement-candidate-created
PAYMENT_KAFKA_TOPIC_SETTLEMENT_PAYOUT_REQUESTED=settlement.seller-payout-requested
PAYMENT_KAFKA_TOPIC_SETTLEMENT_PAYOUT_RESULT=payment.seller-payout-result
PAYMENT_KAFKA_TOPIC_AUTO_PURCHASE_CONFIRMED=payment.auto-purchase-confirmed
PAYMENT_KAFKA_CONSUMER_GROUP_MEMBER_CREATED=payment-service
PAYMENT_KAFKA_CONSUMER_GROUP_ORDER_PAYMENT_REQUESTED=payment-service
PAYMENT_KAFKA_CONSUMER_GROUP_ORDER_DELIVERY_COMPLETED=payment-service
PAYMENT_KAFKA_CONSUMER_GROUP_ORDER_PURCHASE_CONFIRMED=payment-service
PAYMENT_KAFKA_CONSUMER_GROUP_SETTLEMENT_PAYOUT_REQUESTED=payment-service
PAYMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_REQUESTED_DLQ_TOPIC=settlement.seller-payout-requested.dlq
PAYMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_REQUESTED_INITIAL_INTERVAL_MS=1000
PAYMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_REQUESTED_MULTIPLIER=2.0
PAYMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_REQUESTED_MAX_INTERVAL_MS=10000
PAYMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_REQUESTED_MAX_RETRIES=3

SETTLEMENT_KAFKA_TOPIC_SETTLEMENT_CANDIDATE_CREATED=payment.settlement-candidate-created
SETTLEMENT_KAFKA_TOPIC_SETTLEMENT_PAYOUT_REQUESTED=settlement.seller-payout-requested
SETTLEMENT_KAFKA_TOPIC_SETTLEMENT_PAYOUT_RESULT=payment.seller-payout-result
SETTLEMENT_KAFKA_CONSUMER_GROUP_SETTLEMENT_CANDIDATE_CREATED=settlement-service
SETTLEMENT_KAFKA_CONSUMER_GROUP_SETTLEMENT_PAYOUT_RESULT=settlement-service
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_CANDIDATE_CREATED_DLQ_TOPIC=payment.settlement-candidate-created.dlq
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_CANDIDATE_CREATED_INITIAL_INTERVAL_MS=1000
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_CANDIDATE_CREATED_MULTIPLIER=2.0
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_CANDIDATE_CREATED_MAX_INTERVAL_MS=10000
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_CANDIDATE_CREATED_MAX_RETRIES=3
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_RESULT_DLQ_TOPIC=payment.seller-payout-result.dlq
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_RESULT_INITIAL_INTERVAL_MS=1000
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_RESULT_MULTIPLIER=2.0
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_RESULT_MAX_INTERVAL_MS=10000
SETTLEMENT_KAFKA_RETRY_SETTLEMENT_PAYOUT_RESULT_MAX_RETRIES=3

# HMAC-SHA256 최소 32자(256bit) 이상이어야 합니다. 짧으면 기동 오류 발생
JWT_SECRET_KEY=goods-mall-jwt-secret-key-for-dev-use-only-change-in-prod
ACCOUNT_VERIFICATION_SECRET_KEY=local-dev-account-verification-secret-key
# Docker Compose 내부 통신 기준 (로컬 단독 실행 시 http://localhost:8761/eureka/ 사용)
EUREKA_DEFAULT_ZONE=http://discovery:8761/eureka/

TOSS_PAYMENTS_BASE_URL=https://api.tosspayments.com
TOSS_PAYMENTS_CLIENT_KEY=test_gck_your_client_key
TOSS_PAYMENTS_SECRET_KEY=test_gsk_your_secret_key
TOSS_PAYMENTS_SUCCESS_URL=http://localhost:3000/payments/toss/success
TOSS_PAYMENTS_FAIL_URL=http://localhost:3000/payments/toss/fail
TOSS_PAYMENTS_WIDGET_ENABLED=true

# AI (pgvector recommendation)
OPENAI_API_KEY=sk-replace-me
PROJECT_OPENAI_BASE_URL=https://api.openai.com
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_RECOMMENDATION_RERANK_ENABLED=false
AI_RECOMMENDATION_RERANK_MODEL=gpt-5.4-nano
AI_RECOMMENDATION_RERANK_TEMPERATURE=0.0
AI_RECOMMENDATION_RERANK_CONNECT_TIMEOUT_MS=1500
AI_RECOMMENDATION_RERANK_READ_TIMEOUT_MS=2500
AI_RECOMMENDATION_CACHE_TTL_SECONDS=600
AI_EVENT_IDEMPOTENCY_TTL_SECONDS=259200
