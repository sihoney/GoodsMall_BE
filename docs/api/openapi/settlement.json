{
  "openapi": "3.1.0",
  "info": {
    "title": "Settlement Service API",
    "description": "settlement service API documentation\n\n**권장 테스트 순서**\n1. member-service `POST /api/auth/login` 호출\n2. 응답의 `accessToken` 복사\n3. settlement-service 우측 상단 Authorize에 `Bearer <accessToken>` 입력\n\n**admin seed 계정**\n- email: `admin@test.local`\n- password: `test1234!`\n- memberId: `33333333-3333-3333-3333-333333333303`\n- role: `ADMIN`\n\n운영 시나리오 검증은 admin 토큰 사용을 권장합니다.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "/",
      "description": "Gateway relative url"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Seller Partial Settlement",
      "description": "판매자 부분 정산 조회 API"
    },
    {
      "name": "Settlement Ops",
      "description": "정산 운영 조치 API"
    },
    {
      "name": "Seller Settlement",
      "description": "판매자 정산 조회 API"
    }
  ],
  "paths": {
    "/api/settlements/seller/partial-settlements": {
      "post": {
        "tags": [
          "Seller Partial Settlement"
        ],
        "summary": "판매자 부분 정산 실행",
        "operationId": "executePartialSettlement",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PartialSettlementExecutionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePartialSettlementExecutionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/settlements/failed-payout/replay": {
      "post": {
        "tags": [
          "Settlement Ops"
        ],
        "summary": "FAILED 정산건 DLQ replay 처리",
        "operationId": "replayFailedPayouts",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FailedPayoutReplayRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseObject"
                }
              }
            }
          }
        }
      }
    },
    "/api/settlements/failed-payout/manual-retry": {
      "post": {
        "tags": [
          "Settlement Ops"
        ],
        "summary": "FAILED 정산건 수동 재지급 요청",
        "operationId": "requestManualFailedPayout",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualFailedPayoutRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseObject"
                }
              }
            }
          }
        }
      }
    },
    "/internal/settlements/sellers/{sellerId}/withdrawal-summary": {
      "get": {
        "tags": [
          "settlement-internal-controller"
        ],
        "operationId": "getSellerWithdrawalSummary",
        "parameters": [
          {
            "name": "sellerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseSettlementSellerWithdrawalSummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/settlements/seller": {
      "get": {
        "tags": [
          "Seller Settlement"
        ],
        "summary": "판매자 정산 목록 조회",
        "operationId": "findSettlements",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "MONTHLY",
                "PARTIAL"
              ]
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "PENDING",
                "PROCESSING",
                "COMPLETED",
                "FAILED"
              ]
            }
          },
          {
            "name": "year",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "month",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePagedResponseSellerSettlementListItemResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/settlements/seller/{settlementId}": {
      "get": {
        "tags": [
          "Seller Settlement"
        ],
        "summary": "판매자 정산 상세 조회",
        "operationId": "findSettlementDetail",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          },
          {
            "name": "settlementId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseSellerSettlementDetailResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/settlements/seller/partial-settlements/available": {
      "get": {
        "tags": [
          "Seller Partial Settlement"
        ],
        "summary": "판매자 부분 정산 가능 항목 조회",
        "operationId": "findAvailableItemsForPartialSettlement",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListPartialSettlementAvailableItemResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthenticatedMember": {
        "type": "object",
        "properties": {
          "memberId": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string",
            "enum": [
              "USER",
              "SELLER",
              "ADMIN"
            ]
          },
          "sessionId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "PartialSettlementExecutionRequest": {
        "type": "object",
        "properties": {
          "settlementItemIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "minItems": 1
          }
        },
        "required": [
          "settlementItemIds"
        ]
      },
      "ApiErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ApiResponsePartialSettlementExecutionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/PartialSettlementExecutionResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          }
        }
      },
      "PartialSettlementExecutionResponse": {
        "type": "object",
        "properties": {
          "settlementId": {
            "type": "string",
            "format": "uuid"
          },
          "sellerId": {
            "type": "string",
            "format": "uuid"
          },
          "settlementType": {
            "type": "string",
            "enum": [
              "MONTHLY",
              "PARTIAL"
            ]
          },
          "settlementStatus": {
            "type": "string",
            "enum": [
              "PENDING",
              "PROCESSING",
              "COMPLETED",
              "FAILED"
            ]
          },
          "settlementItemCount": {
            "type": "integer",
            "format": "int32"
          },
          "totalSalesAmount": {
            "type": "number"
          },
          "feeAmount": {
            "type": "number"
          },
          "finalSettlementAmount": {
            "type": "number"
          }
        }
      },
      "FailedPayoutReplayRequest": {
        "type": "object",
        "properties": {
          "settlementIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ApiResponseObject": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {},
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          }
        }
      },
      "ManualFailedPayoutRequest": {
        "type": "object",
        "properties": {
          "settlementId": {
            "type": "string"
          }
        }
      },
      "ApiResponseSettlementSellerWithdrawalSummaryResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/SettlementSellerWithdrawalSummaryResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          }
        }
      },
      "SettlementSellerWithdrawalSummaryResponse": {
        "type": "object",
        "properties": {
          "hasPendingSettlement": {
            "type": "boolean"
          },
          "hasProcessingSettlement": {
            "type": "boolean"
          },
          "hasPartialSettlementAvailable": {
            "type": "boolean"
          }
        }
      },
      "ApiResponsePagedResponseSellerSettlementListItemResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/PagedResponseSellerSettlementListItemResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          }
        }
      },
      "PagedResponseSellerSettlementListItemResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SellerSettlementListItemResponse"
            }
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "totalElements": {
            "type": "integer",
            "format": "int64"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "hasNext": {
            "type": "boolean"
          }
        }
      },
      "SellerSettlementListItemResponse": {
        "type": "object",
        "properties": {
          "settlementId": {
            "type": "string",
            "format": "uuid"
          },
          "sellerId": {
            "type": "string",
            "format": "uuid"
          },
          "settlementType": {
            "type": "string",
            "enum": [
              "MONTHLY",
              "PARTIAL"
            ]
          },
          "settlementYear": {
            "type": "integer",
            "format": "int32"
          },
          "settlementMonth": {
            "type": "integer",
            "format": "int32"
          },
          "totalSalesAmount": {
            "type": "number"
          },
          "feeAmount": {
            "type": "number"
          },
          "finalSettlementAmount": {
            "type": "number"
          },
          "settledAmount": {
            "type": "number"
          },
          "settlementStatus": {
            "type": "string",
            "enum": [
              "PENDING",
              "PROCESSING",
              "COMPLETED",
              "FAILED"
            ]
          },
          "settledAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastFailureReason": {
            "type": "string"
          },
          "requestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ApiResponseSellerSettlementDetailResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/SellerSettlementDetailResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          }
        }
      },
      "SellerSettlementDetailItemResponse": {
        "type": "object",
        "properties": {
          "settlementItemId": {
            "type": "string",
            "format": "uuid"
          },
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "escrowId": {
            "type": "string",
            "format": "uuid"
          },
          "grossAmount": {
            "type": "number"
          },
          "feeAmount": {
            "type": "number"
          },
          "netAmount": {
            "type": "number"
          },
          "releasedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SellerSettlementDetailResponse": {
        "type": "object",
        "properties": {
          "settlementId": {
            "type": "string",
            "format": "uuid"
          },
          "sellerId": {
            "type": "string",
            "format": "uuid"
          },
          "settlementType": {
            "type": "string",
            "enum": [
              "MONTHLY",
              "PARTIAL"
            ]
          },
          "settlementYear": {
            "type": "integer",
            "format": "int32"
          },
          "settlementMonth": {
            "type": "integer",
            "format": "int32"
          },
          "totalSalesAmount": {
            "type": "number"
          },
          "feeAmount": {
            "type": "number"
          },
          "finalSettlementAmount": {
            "type": "number"
          },
          "settledAmount": {
            "type": "number"
          },
          "settlementStatus": {
            "type": "string",
            "enum": [
              "PENDING",
              "PROCESSING",
              "COMPLETED",
              "FAILED"
            ]
          },
          "settledAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastFailureReason": {
            "type": "string"
          },
          "requestedAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SellerSettlementDetailItemResponse"
            }
          }
        }
      },
      "ApiResponseListPartialSettlementAvailableItemResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PartialSettlementAvailableItemResponse"
            }
          },
          "error": {
            "$ref": "#/components/schemas/ApiErrorResponse"
          }
        }
      },
      "PartialSettlementAvailableItemResponse": {
        "type": "object",
        "properties": {
          "settlementItemId": {
            "type": "string",
            "format": "uuid"
          },
          "escrowId": {
            "type": "string",
            "format": "uuid"
          },
          "orderId": {
            "type": "string",
            "format": "uuid"
          },
          "grossAmount": {
            "type": "number"
          },
          "feeAmount": {
            "type": "number"
          },
          "netAmount": {
            "type": "number"
          },
          "releasedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "description": "member-service 로그인으로 받은 accessToken을 입력하면 gateway가 X-Member-Id / X-Member-Role 헤더를 내부적으로 주입합니다.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
