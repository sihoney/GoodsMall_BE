        "operationId": "reindexAll",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "integer",
                    "format": "int32"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/products/{productId}/stock/increase": {
      "patch": {
        "tags": [
          "Product"
        ],
        "summary": "재고 증가",
        "description": "상품의 재고를 증가시킵니다 (입고). 재고가 0이었다면 SOLD_OUT → ACTIVE 상태로 자동 전환됩니다.",
        "operationId": "increaseStock",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          },
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StockAdjustmentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "재고 증가 성공",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ProductResponse"
                }
              }
            }
          },
          "400": {
            "description": "잘못된 요청",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ProductResponse"
                }
              }
            }
          },
          "403": {
            "description": "권한 없음 (판매자 불일치)",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ProductResponse"
                }
              }
            }
          },
          "404": {
            "description": "상품을 찾을 수 없음",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ProductResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/products/{productId}/stock/decrease": {
      "patch": {
        "tags": [
          "Product"
        ],
        "summary": "재고 감소",
        "description": "상품의 재고를 감소시킵니다 (출고, 판매 등). 재고가 부족하면 예외가 발생합니다. 재고가 0이 되면 ACTIVE → SOLD_OUT 상태로 자동 전환됩니다.",
        "operationId": "decreaseStock",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          },
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StockAdjustmentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "재고 감소 성공",
