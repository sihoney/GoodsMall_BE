{
  "openapi": "3.1.0",
  "info": {
    "title": "Notification Service API",
    "description": "notification service API documentation",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:8087",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "알림",
      "description": "알림 API"
    },
    {
      "name": "알림 SSE",
      "description": "알림 SSE API"
    }
  ],
  "paths": {
    "/api/notifications/{notificationId}/read": {
      "patch": {
        "tags": [
          "알림"
        ],
        "summary": "알림 읽음 처리",
        "operationId": "markAsRead",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          },
          {
            "name": "notificationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseNotificationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/notifications": {
      "get": {
        "tags": [
          "알림"
        ],
        "summary": "내 알림 목록 조회",
        "operationId": "getMyNotifications",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePagedResponseNotificationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/notifications/unread-count": {
      "get": {
        "tags": [
          "알림"
        ],
        "summary": "읽지 않은 알림 개수 조회",
        "operationId": "getUnreadCount",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseNotificationUnreadCountResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/notifications/stream": {
      "get": {
        "tags": [
          "알림 SSE"
        ],
        "summary": "알림 SSE 구독",
        "operationId": "subscribe",
        "parameters": [
          {
            "name": "authenticatedMember",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AuthenticatedMember"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/SseEmitter"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthenticatedMember": {
        "type": "object",
        "properties": {
          "memberId": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string",
            "enum": [
              "USER",
              "SELLER",
              "ADMIN"
            ]
          },
          "sessionId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ApiResponseNotificationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/NotificationResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ErrorResponse"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "NotificationAction": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "actionType": {
            "type": "string"
          },
          "routeKey": {
            "type": "string"
          },
          "referenceId": {
            "type": "string",
            "format": "uuid"
          },
          "variant": {
            "type": "string"
          }
        }
      },
      "NotificationResponse": {
        "type": "object",
        "properties": {
          "notificationId": {
            "type": "string",
            "format": "uuid"
          },
          "type": {
            "type": "string",
            "enum": [
              "BUYER_SIGNUP_COMPLETED",
              "SELLER_PROMOTED",
              "ACCOUNT_VERIFICATION_EXPIRED",
              "ACCOUNT_VERIFICATION_FAILED",
              "MEMBER_OAUTH_LINKED",
              "BUYER_ORDER_CREATED",
              "BUYER_ORDER_CANCELED",
              "BUYER_AUTO_PURCHASE_CONFIRMED",
              "BUYER_ORDER_PAYMENT_SUCCEEDED",
              "BUYER_ORDER_PAYMENT_FAILED",
              "SELLER_ORDER_RECEIVED",
              "SELLER_ORDER_CANCELED",
              "SELLER_SETTLEMENT_PAYOUT_SUCCEEDED",
              "SELLER_SETTLEMENT_PAYOUT_FAILED",
              "BUYER_AUCTION_OUTBID",
              "BUYER_AUCTION_WON",
              "SELLER_AUCTION_CLOSED_SOLD",
              "SELLER_AUCTION_CLOSED_UNSOLD"
            ]
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NotificationAction"
            }
          },
          "referenceId": {
            "type": "string",
            "format": "uuid"
          },
          "referenceType": {
            "type": "string",
            "enum": [
              "PAYMENT",
              "ORDER",
              "SETTLEMENT",
              "WITHDRAWAL",
              "AUCTION"
            ]
          },
          "read": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "elapsedTime": {
            "type": "string"
          },
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "traceId": {
            "type": "string"
          }
        }
      },
      "ApiResponsePagedResponseNotificationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/PagedResponseNotificationResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ErrorResponse"
          }
        }
      },
      "PagedResponseNotificationResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NotificationResponse"
            }
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "totalElements": {
            "type": "integer",
            "format": "int64"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "hasNext": {
            "type": "boolean"
          }
        }
      },
      "ApiResponseNotificationUnreadCountResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "$ref": "#/components/schemas/NotificationUnreadCountResponse"
          },
          "error": {
            "$ref": "#/components/schemas/ErrorResponse"
          }
        }
      },
      "NotificationUnreadCountResponse": {
        "type": "object",
        "properties": {
          "unreadCount": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "SseEmitter": {
        "type": "object",
        "properties": {
          "timeout": {
            "type": "integer",
            "format": "int64"
          }
        }
      }
    }
  }
}
