apiVersion: v1
kind: Secret
metadata:
  name: member-secret
  namespace: goods-mall
type: Opaque
stringData:
  JWT_SECRET_KEY: ""                    # Gateway와 member 서비스가 JWT를 검증/발급할 때 사용하는 서명 키
  AWS_ACCESS_KEY_ID: ""                 # 프로필 이미지용 S3 presigned URL을 생성할 때 사용
  AWS_SECRET_ACCESS_KEY: ""             # 프로필 이미지용 S3 presigned URL을 생성할 때 사용
  KAKAO_CLIENT_SECRET: ""               # Kakao OAuth 토큰 교환과 사용자 정보 조회에 사용
  SMTP_USERNAME: ""                     # SMTP 서버 인증용 사용자명
  SMTP_PASSWORD: ""                     # SMTP 서버 인증용 비밀번호
  ACCOUNT_VERIFICATION_SECRET_KEY: ""   # 계좌 인증 토큰을 보호
